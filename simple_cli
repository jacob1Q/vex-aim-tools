def runfsm(module_name):
    new_fsm = _program_runfsm(module_name)
    globals()['running_fsm'] = aim_fsm.program.running_fsm
    _process_pending_viewer_launches(timeout=0.1)
    return new_fsm


def _ensure_viewer(attr, factory):
    target = globals().get('robot')
    if target is None:
        return None

    viewer = getattr(target, attr, None)
    if viewer and viewer is not True:
        return viewer

    viewer = factory()
    if hasattr(viewer, 'start'):
        viewer.start()
    setattr(target, attr, viewer)
    return viewer


def _prime_default_viewers(program, launch_overrides=None):
    if program is None:
        return

    target_robot = getattr(program, 'robot', None) or globals().get('robot')
    if target_robot is None:
        return

    flags = launch_overrides or {}
    if flags.get('cam', getattr(program, 'launch_cam_viewer', False)):
        # Enable cliff overlay in cached mode (reads from robot.cliff_results, no detector)
        from viewer.cliff_overlay import CliffOverlay
        cliff_overlay = CliffOverlay(detector=None, robot=target_robot)
        _ensure_viewer('cam_viewer', lambda: CamViewer(target_robot, cliff_overlay=cliff_overlay))

    if flags.get('worldmap', getattr(program, 'launch_worldmap_viewer', False)):
        _ensure_viewer('worldmap_viewer', lambda: WorldMapViewer(target_robot))

    if flags.get('particle', getattr(program, 'launch_particle_viewer', False)):
        _ensure_viewer('particle_viewer', lambda: ParticleViewer(target_robot))

    if flags.get('path', getattr(program, 'launch_path_viewer', False)):
        _ensure_viewer('path_viewer', lambda: PathViewer(target_robot))


_pending_viewer_launches = SimpleQueue()


def _capture_launch_flags(program):
    return {
        'cam': bool(getattr(program, 'launch_cam_viewer', False)),
        'worldmap': bool(getattr(program, 'launch_worldmap_viewer', False)),
        'particle': bool(getattr(program, 'launch_particle_viewer', False)),
        'path': bool(getattr(program, 'launch_path_viewer', False)),
    }


_original_state_machine_start = StateMachineProgram.start


def _start_with_main_thread_viewers(self, *args, **kwargs):
    launch_flags = _capture_launch_flags(self)
    on_main_thread = threading.current_thread() is threading.main_thread()
    if not on_main_thread:
        self.launch_cam_viewer = False
        self.launch_worldmap_viewer = False
        self.launch_particle_viewer = False
        self.launch_path_viewer = False
    try:
        return _original_state_machine_start(self, *args, **kwargs)
    finally:
        if not on_main_thread:
            self.launch_cam_viewer = launch_flags['cam']
            self.launch_worldmap_viewer = launch_flags['worldmap']
            self.launch_particle_viewer = launch_flags['particle']
            self.launch_path_viewer = launch_flags['path']
            _pending_viewer_launches.put((self, launch_flags))


StateMachineProgram.start = _start_with_main_thread_viewers


def _drain_pending_viewer_launches_once():
    processed = False
    while True:
        try:
            program, launch_flags = _pending_viewer_launches.get_nowait()
        except Empty:
            break
        _prime_default_viewers(program, launch_flags)
        processed = True
    return processed


def _process_pending_viewer_launches(timeout=0.0):
    if timeout <= 0.0:
        _drain_pending_viewer_launches_once()
        return

    deadline = time.monotonic() + timeout
    while True:
        processed = _drain_pending_viewer_launches_once()
        if processed:
            continue
        remaining = deadline - time.monotonic()
        if remaining <= 0.0:
            break

        # Process Qt events while waiting for viewer launch
        try:
            from PyQt6.QtGui import QGuiApplication
            app = QGuiApplication.instance()
            if app:
                app.processEvents()
        except ImportError:
            pass

        time.sleep(min(0.01, remaining))

def cli_loop(_robot):
    global ans, RUNNING, robot, file_to_run, running_fsm

    robot = _robot

    cli_globals = globals()
    cli_globals['ans'] = None

    running_fsm = aim_fsm.program.running_fsm = None
    cli_globals['running_fsm'] = running_fsm
    if file_to_run:
        time.sleep(0.25)
        running_fsm = runfsm(file_to_run)
        cli_globals['running_fsm'] = running_fsm
    else:
        running_fsm = aim_fsm.program.running_fsm = StateMachineProgram()
        cli_globals['running_fsm'] = running_fsm
        robot.loop.call_soon_threadsafe(running_fsm.start)

    cli_loop._console = code.InteractiveConsole()
    _process_pending_viewer_launches(timeout=0.5)
    while True:
        if RUNNING == False:
            return
        cli_loop._line = ''
        while cli_loop._line == '':
            running_fsm = aim_fsm.program.running_fsm
            _process_pending_viewer_launches()
            readline.write_history_file(histfile)

            # Process Qt events if signal requested it
            global _qt_needs_processing
            if _qt_needs_processing:
                _qt_needs_processing = False
                try:
                    from PyQt6.QtGui import QGuiApplication
                    app = QGuiApplication.instance()
                    if app:
                        app.processEvents()
                except ImportError:
                    pass

            try:
                sys.stdout.flush()
                cli_loop._line = cli_loop._console.raw_input('C> ').strip()
            except KeyboardInterrupt:
                process_interrupt()
                continue
            except EOFError:
                print("EOF.\nType 'exit' to exit.\n")
                continue
            try:
                robot.kine.get_pose()
            except: pass
        if cli_loop._line[0] == '!':
            do_shell_command(cli_loop._line[1:])
            continue
        elif cli_loop._line == '.':
            continue
        elif cli_loop._line[0:2] == '. ':
            do_hear_command(cli_loop._line[2:])
            continue
        elif cli_loop._line[0:3] == 'tm ' or cli_loop._line == 'tm':
            text_message(cli_loop._line[3:])
            continue
        elif cli_loop._line[0:5] == 'show ' or cli_loop._line == 'show':
            show_args = cli_loop._line[5:].split(' ')
            try:
                show_stuff(show_args)
            except Exception:
                traceback.print_exc()
                print()
            continue
        elif cli_loop._line[0:7] == 'reload ':
            do_reload(cli_loop._line[7:])
            continue
        elif cli_loop._line[0:6] == 'start ' or cli_loop._line == 'start':
            start_args = cli_loop._line[6:].split(' ')
            start_stuff(start_args)
            continue
        elif cli_loop._line[0:5] == 'stop ' or cli_loop._line == 'stop':
            stop_args = cli_loop._line[5:].split(' ')
            stop_stuff(stop_args)
            continue
        elif cli_loop._line[0:13] == 'detect_cliff ' or cli_loop._line == 'detect_cliff':
            detect_cliff_args = cli_loop._line[13:].split(' ')
            detect_cliff(detect_cliff_args)
            continue
        elif cli_loop._line[0:12] == 'clear_cliffs' or cli_loop._line == 'clear_cliffs':
            clear_cliff_args = cli_loop._line[12:].split(' ')
            clear_cliffs(clear_cliff_args)
            continue
        elif cli_loop._line[0:9] == 'scan_map ' or cli_loop._line == 'scan_map':
            scan_map_args = cli_loop._line[9:].split(' ')
            scan_map(scan_map_args)
            continue
        elif cli_loop._line[0:14] == 'start_mapping ' or cli_loop._line == 'start_mapping':
            start_mapping_args = cli_loop._line[14:].split(' ')
            start_mapping(start_mapping_args)
            continue
        cli_loop._do_await = False
        if cli_loop._line[0:7] == 'import ' or cli_loop._line[0:5] == 'from '  or \
               cli_loop._line[0:7] == 'global ' or cli_loop._line[0:4] == 'del '   or \
               cli_loop._line[0:4] == 'for ' or cli_loop._line[0:6] == 'while ' or \
               cli_loop._line[0:4] == 'def '    or cli_loop._line[0:6] == 'async ' :
            # Can't use assignment to capture a return value, so None.
            ans = None
        elif cli_loop._line[0:6] == 'await ':
            cli_loop._do_await = True
            cli_loop._line = 'ans=' + cli_loop._line[6:]
        elif cli_loop._line[0:5] == 'exit':
            loop.stop()
            # Clean up
            try:
                world_viewer.exited = True
            except: pass
            if running_fsm:
                running_fsm.stop()
            print('exiting...')
            RUNNING=False
            continue
        else:
            cli_loop._line = 'ans=' + cli_loop._line
        try:
            exec(cli_loop._line, cli_globals)
            if cli_loop._do_await:
                print("Can't use await outside of an async def.")
                ans = None # ans = await ans
            if not ans is None:
                print(ans,end='\n\n')
        except KeyboardInterrupt:
            print('Keyboard interrupt!')
        except SystemExit:
            print('Type exit() again to exit Python.')
            RUNNING = False
        except Exception:
            traceback.print_exc()
            print()
        finally:
            _process_pending_viewer_launches()

def process_interrupt():
    robot.robot0.stop_all_movement()
    running_fsm = aim_fsm.program.running_fsm
    if running_fsm and running_fsm.running:
        print('\nKeyboardInterrupt: stopping', running_fsm.name)
        running_fsm.stop()
    else:
        print("\nKeyboardInterrupt. Type 'exit' to exit.")

