def show_stuff(args):
    global running_fsm
    running_fsm = aim_fsm.program.running_fsm
    spec = args[0] if len(args) > 0 else ""
    if spec == 'active':
        if not running_fsm:
            print('No state machine present.')
        elif not running_fsm.running:
            print("State machine '%s' is not running." % running_fsm.name)
        else:
            show_active(running_fsm,0)
    elif spec == "battery":
        print(f'Battery capacity {robot.robot0.get_battery_capacity()}%\n')
    elif spec == "kine":
        show_kine(args[1:])
    elif spec == 'cam_viewer' or spec=='viewer':
        if running_fsm:
            running_fsm.cam_viewer = True
        _ensure_viewer('cam_viewer', lambda: CamViewer(robot))
    elif spec == "crosshairs":
        viewer = _ensure_viewer('cam_viewer', lambda: CamViewer(robot))
        if viewer is not None:
            viewer.crosshairs = not viewer.crosshairs
    elif spec == "particle_viewer":
        _ensure_viewer('particle_viewer', lambda: ParticleViewer(robot))
    elif spec == "path_viewer":
        _ensure_viewer('path_viewer', lambda: PathViewer(robot))
    elif spec == "worldmap_viewer":
        _ensure_viewer('worldmap_viewer', lambda: WorldMapViewer(robot))
    elif (spec == "all") or (spec == "all_viewers"):
        if running_fsm:
            running_fsm.cam_viewer = True
        _ensure_viewer('cam_viewer', lambda: CamViewer(robot))
        _ensure_viewer('worldmap_viewer', lambda: WorldMapViewer(robot))
        _ensure_viewer('particle_viewer', lambda: ParticleViewer(robot))
        _ensure_viewer('path_viewer', lambda: PathViewer(robot))
    elif spec == "pose":
        robot.show_pose()
    elif spec == "objects":
        robot.world_map.show_objects()
    elif spec == "landmarks":
        robot.particle_filter.show_landmarks()
    elif spec == "particle":
        robot.particle_filter.show_particle(args[1:])
#    elif spec == "camera":
#        show_camera(args[1:])
    else:
        print("""Invalid option. Try one of:
  show all | all_viewers           Launch every viewer (PyQt6)
  show active                      Display running FSM stack
  show battery                     Query robot battery level
  show crosshairs                  Toggle camera crosshairs
  show kine [joint]                Dump kinematics state
  show landmarks                   Print SLAM landmarks
  show objects                     Print world objects
  show particle n                  Highlight particle n
  show pose                        Print robot pose
  show viewer | cam_viewer         Open PyQt6 camera viewer
  show particle_viewer             Open PyQt6 particle viewer
  show worldmap_viewer             Open PyQt6 world map viewer
  show path_viewer                 Open PyQt6 path/wavefront viewer
