from aim_fsm import *

class GPT_test(StateMachineProgram):
    class SpeakResponse(Say):
      def start(self,event):
        self.text = event.response
        super().start(event)
        
    $setup{
      Say("Talk to me") =C=> loop

      loop: StateNode() =Hear()=> AskGPT() =OpenAITrans()=> self.SpeakResponse() =C=> loop
    }

